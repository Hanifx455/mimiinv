rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isAuthenticated() && 
             (request.auth.uid == "1Gb3hZ35MhbAaoKcnlqq3AwOTJn2" || 
              ("email" in request.auth.token && request.auth.token.email == "hanilegro@gmail.com"));
    }

    // Global Admin Override - This should be the first rule
    match /{document=**} {
      allow read, write: if isAdmin();
    }

    // Specific rules for users
    match /users/{userId} {
      allow read, write: if isAuthenticated() && request.auth.uid == userId;
    }
    
    match /notifications/{notificationId} {
      allow read: if isAuthenticated() && (isAdmin() || resource.data.userId == request.auth.uid);
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAuthenticated() && (isAdmin() || resource.data.userId == request.auth.uid);
    }

    match /transactions/{transactionId} {
      allow read: if isAuthenticated() && (isAdmin() || resource.data.userId == request.auth.uid);
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAdmin();
    }
    
    match /investments/{investmentId} {
      allow read: if isAuthenticated() && (isAdmin() || resource.data.userId == request.auth.uid);
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated() && (isAdmin() || resource.data.userId == request.auth.uid);
      allow delete: if isAdmin();
    }

    match /alerts/{alertId} {
      allow read: if isAuthenticated() && (isAdmin() || resource.data.userId == request.auth.uid);
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAuthenticated() && (isAdmin() || resource.data.userId == request.auth.uid);
    }

    match /referrals/{referralId} {
      allow read: if isAuthenticated() && (isAdmin() || resource.data.referrerId == request.auth.uid);
      allow create: if isAuthenticated() && request.resource.data.referrerId == request.auth.uid;
      allow update, delete: if isAdmin();
    }
  }
}
